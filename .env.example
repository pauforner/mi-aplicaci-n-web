# OpenAI — NUNCA añadir prefijo NEXT_PUBLIC_
OPENAI_API_KEY=sk-proj-...

# URL de la app (cambia a tu URL de Vercel en producción)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — dashboard.stripe.com/test/apikeys (NUNCA añadir NEXT_PUBLIC_ a las secretas)
